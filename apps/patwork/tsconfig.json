{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "paths": {
      "@patwork/*": ["./src/*"],
      "@patwork/provider": ["./provider/index.ts"],
      "@patwork/content": ["./content/index.ts"],
      // "@patwork/settings/*": ["./settings/*"],
      // "@patwork/styles/*": ["./styles/*"],
      // "@patwork/queries": ["./queries/index.ts"],
      // "@patwork/types": ["./types/index.ts"]
    },
  "include": [
    "next-env.d.ts",
    "next.config.js",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
