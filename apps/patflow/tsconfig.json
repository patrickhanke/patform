{
  "extends": "@repo/typescript/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@provider": ["./provider/index.ts"],
      "@settings/*": ["./settings/*"],
      "@styles/*": ["./styles/*"],
      "@content": ["./content/index.ts"],
      "@queries": ["./queries/index.ts"],
      "@types": ["./types/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "next.config.js",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "custom.d.ts"
  ],
  "exclude": ["node_modules","next.config.js", "eslint.config.mjs", "jest.config.js"]
}
