{
  "extends": "@repo/typescript-config/react-library.json",
  "compilerOptions": {
    // "outDir": "dist",
    "esModuleInterop": true,
    "module": "ESNext", 
    "moduleResolution": "Bundler",
    "paths": {
      "@repo/ui/*": ["./packages/ui/*"],
      "@repo/provider/*": ["./packages/provider/*"],
      "@repo/types/*": ["./packages/types/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
