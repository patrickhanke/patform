# Parse Server / SashiDo Configuration

# REST API Base URL (for /api/data routes)
SASHIDO_API_URL=https://your-server.com/parse

# GraphQL URL (for /api/graphql routes)
SASHIDO_GQL_URL=https://your-server.com/graphql

# Server-side credentials (used by edge functions)
SASHIDO_APP_ID=your-application-id
SASHIDO_REST_KEY=your-rest-api-key
SASHIDO_MASTER_KEY=your-master-key

# Session cookie name
SESSION_TOKEN=patstore_token

# Client-side credentials (for original Apollo hooks - requires NEXT_PUBLIC_ prefix)
# Note: These expose credentials in browser - use secure hooks instead!
NEXT_PUBLIC_SASHIDO_GQL_URL=https://your-server.com/graphql
NEXT_PUBLIC_SASHIDO_APP_ID=your-application-id
NEXT_PUBLIC_SASHIDO_REST_KEY=your-rest-api-key
