# Root `.env` for the patform monorepo.
# App-specific values use a PATFLOW_ or PATSTORE_ prefix.
# Each app's next.config.js maps these to runtime names (e.g. PATFLOW_SASHIDO_API_URL → SASHIDO_API_URL).

# --- patflow (workforce app) ---

PATFLOW_SASHIDO_API_URL=https://your-patflow-server.com/parse/
PATFLOW_SASHIDO_GQL_URL=https://your-patflow-server.com/graphql/
PATFLOW_SASHIDO_APP_ID=your-patflow-application-id
PATFLOW_SASHIDO_REST_KEY=your-patflow-rest-api-key
PATFLOW_SASHIDO_MASTER_KEY=your-patflow-master-key
PATFLOW_SASHIDO_JS_KEY=your-patflow-javascript-key
PATFLOW_SASHIDO_FILE_URL=https://your-patflow-files.example.com/
PATFLOW_SASHIDO_CLIENT_KEY=your-patflow-client-key
PATFLOW_SESSION_TOKEN=patflow_session_token
PATFLOW_APP_NAME=patflow
PATFLOW_INSTALLATION_ID=patflow_installation_id

PATFLOW_FIREBASE_API_KEY=your-patflow-firebase-api-key
PATFLOW_FIREBASE_AUTH_DOMAIN=your-patflow.firebaseapp.com
PATFLOW_FIREBASE_PROJECT_ID=your-patflow-project
PATFLOW_FIREBASE_STORAGE_BUCKET=your-patflow.firebasestorage.app
PATFLOW_FIREBASE_MESSAGING_SENDER_ID=000000000000
PATFLOW_FIREBASE_APP_ID=1:000000000000:web:yourpatflowapp
PATFLOW_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
PATFLOW_GCMS_SENDER_ID=000000000000

# --- patstore (CMS app) ---

PATSTORE_SASHIDO_API_URL=https://your-patstore-server.com/parse/
PATSTORE_SASHIDO_GQL_URL=https://your-patstore-server.com/graphql/
PATSTORE_SASHIDO_APP_ID=your-patstore-application-id
PATSTORE_SASHIDO_REST_KEY=your-patstore-rest-api-key
PATSTORE_SASHIDO_MASTER_KEY=your-patstore-master-key
PATSTORE_SASHIDO_JS_KEY=your-patstore-javascript-key
PATSTORE_SASHIDO_FILE_URL=https://your-patstore-files.example.com/
PATSTORE_SASHIDO_CLIENT_KEY=your-patstore-client-key
PATSTORE_SESSION_TOKEN=patstore_token
PATSTORE_APP_NAME=patstore

PATSTORE_FIREBASE_API_KEY=your-patstore-firebase-api-key
PATSTORE_FIREBASE_AUTH_DOMAIN=your-patstore.firebaseapp.com
PATSTORE_FIREBASE_PROJECT_ID=your-patstore-project
PATSTORE_FIREBASE_STORAGE_BUCKET=your-patstore.firebasestorage.app
PATSTORE_FIREBASE_MESSAGING_SENDER_ID=000000000000
PATSTORE_FIREBASE_APP_ID=1:000000000000:web:yourpatstoreapp
PATSTORE_GCMS_SENDER_ID=000000000000

PATSTORE_NEXT_PUBLIC_LETTERMINT_API_KEY=your-lettermint-api-key
PATSTORE_NEXT_LETTERMINT_KEY=your-lettermint-team-key

# --- patstore file uploads (Bytescale, loaded from .env — not via next.config) ---

BYTESCALE_ACCOUNT_ID=your-bytescale-account-id
BYTESCALE_SECRET_KEY=your-bytescale-secret-key
NEXT_PUBLIC_BYTESCALE_PUBLIC_KEY=your-bytescale-public-key

# --- optional shared ---

NODE_ENV=development
