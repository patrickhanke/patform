{
  "name": "patwork",
  "private": true,
  "version": "0.3.0",
  "scripts": {
    "build": "dotenv -- turbo build",
    "dev": "dotenv -- turbo dev",
    "dev:patstore": "dotenv -- turbo dev --filter=patstore",
    "dev:patflow": "dotenv -- turbo dev --filter=patflow",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "typecheck:ci": "turbo typecheck --filter=@repo/provider",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-deps": "manypkg check",
    "syncpack:check": "syncpack list-mismatches",
    "gen": "turbo gen",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@manypkg/cli": "^0.23.0",
    "@types/lodash-es": "^4.17.12",
    "react-email": "4.2.11",
    "syncpack": "^13.0.0",
    "turbo": "latest",
    "typescript": "^5.4.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@9.6.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@react-email/components": "0.5.3",
    "firebase": "^11.1.0",
    "idb": "^8.0.1",
    "js-cookie": "^3.0.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^5.0.11"
  }
}
