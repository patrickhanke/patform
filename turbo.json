{
  "$schema": "https://turbo.build/schema.json",
  "globalDotEnv": [".env"],
  "globalEnv": [ 
    "SASHIDO_API_URL",
    "SASHIDO_APP_ID",
    "SASHIDO_REST_KEY",
    "SASHIDO_MASTER_KEY",
    "SASHIDO_FILE_URL",
    "SASHIDO_CLIENT_KEY"
  ],
  "pipeline": {
    "build": {
      "dotEnv": [".env"],
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "dotEnv": [".env"],
      "cache": false,
      "persistent": true
    }
  }
}
