{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "PATFLOW_SASHIDO_API_URL",
    "PATFLOW_SASHIDO_GQL_URL",
    "PATFLOW_SASHIDO_APP_ID",
    "PATFLOW_SASHIDO_REST_KEY",
    "PATFLOW_SASHIDO_MASTER_KEY",
    "PATFLOW_SASHIDO_JS_KEY",
    "PATFLOW_SASHIDO_FILE_URL",
    "PATFLOW_SASHIDO_CLIENT_KEY",
    "PATFLOW_SESSION_TOKEN",
    "PATFLOW_APP_NAME",
    "PATFLOW_INSTALLATION_ID",
    "PATFLOW_FIREBASE_API_KEY",
    "PATFLOW_FIREBASE_AUTH_DOMAIN",
    "PATFLOW_FIREBASE_PROJECT_ID",
    "PATFLOW_FIREBASE_STORAGE_BUCKET",
    "PATFLOW_FIREBASE_MESSAGING_SENDER_ID",
    "PATFLOW_FIREBASE_APP_ID",
    "PATFLOW_FIREBASE_MEASUREMENT_ID",
    "PATFLOW_GCMS_SENDER_ID",
    "PATSTORE_SASHIDO_API_URL",
    "PATSTORE_SASHIDO_GQL_URL",
    "PATSTORE_SASHIDO_APP_ID",
    "PATSTORE_SASHIDO_REST_KEY",
    "PATSTORE_SASHIDO_MASTER_KEY",
    "PATSTORE_SASHIDO_JS_KEY",
    "PATSTORE_SASHIDO_FILE_URL",
    "PATSTORE_SASHIDO_CLIENT_KEY",
    "PATSTORE_SESSION_TOKEN",
    "PATSTORE_APP_NAME",
    "PATSTORE_FIREBASE_API_KEY",
    "PATSTORE_FIREBASE_AUTH_DOMAIN",
    "PATSTORE_FIREBASE_PROJECT_ID",
    "PATSTORE_FIREBASE_STORAGE_BUCKET",
    "PATSTORE_FIREBASE_MESSAGING_SENDER_ID",
    "PATSTORE_FIREBASE_APP_ID",
    "PATSTORE_GCMS_SENDER_ID",
    "PATSTORE_NEXT_LETTERMINT_KEY",
    "BYTESCALE_ACCOUNT_ID",
    "BYTESCALE_SECRET_KEY",
    "NEXT_PUBLIC_BYTESCALE_PUBLIC_KEY",
    "NODE_ENV"
  ],
  "globalDependencies": [".env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "inputs": ["$TURBO_DEFAULT$", ".env"],
      "outputLogs": "full"
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "inputs": ["$TURBO_DEFAULT$", ".env"]
    }
  }
}
