{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "BYTESCALE_ACCOUNT_ID",
    "BYTESCALE_PUBLIC_KEY",
    "BYTESCALE_SECRET_KEY",
    "SESSION_TOKEN",
    "SASHIDO_APP_ID",
    "SASHIDO_API_URL",
    "SASHIDO_GQL_URL",
    "SASHIDO_REST_KEY",
    "SASHIDO_MASTER_KEY",
    "SASHIDO_JS_KEY",
    "SASHIDO_FILE_URL",
    "SASHIDO_CLIENT_KEY",
    "FIREBASE_API_KEY",
    "FIREBASE_AUTH_DOMAIN",
    "FIREBASE_PROJECT_ID",
    "FIREBASE_STORAGE_BUCKET",
    "FIREBASE_MESSAGING_SENDER_ID",
    "FIREBASE_APP_ID",
    "GCMS_SENDER_ID",
    "PROJECT_ID",
    "APP_NAME",
    "NODE_ENV"
  ],
  "globalDependencies": [".env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "inputs": ["$TURBO_DEFAULT$", ".env"],
      "outputLogs": "full"
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "inputs": ["$TURBO_DEFAULT$", ".env"]
    }
  }
}
