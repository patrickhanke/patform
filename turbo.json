{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "BYTESCALE_ACCOUNT_ID",
    "BYTESCALE_PUBLIC_KEY",
    "BYTESCALE_SECRET_KEY"
  ],
  "globalDependencies": [".env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "inputs": ["$TURBO_DEFAULT$", ".env"],
      "outputLogs": "full"
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "inputs": ["$TURBO_DEFAULT$", ".env"]
    }
  }
}
